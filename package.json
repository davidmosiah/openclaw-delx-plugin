{
  "name": "openclaw-delx-plugin",
  "version": "0.1.0",
  "description": "Free Delx recovery and heartbeat tools for OpenClaw agents with automatic registration and session reuse",
  "type": "module",
  "files": [
    "index.js",
    "openclaw.plugin.json",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node --test test/**/*.test.js"
  },
  "keywords": [
    "openclaw",
    "clawhub",
    "plugin",
    "delx",
    "agent-recovery",
    "ai-agents",
    "a2a",
    "mcp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidmosiah/openclaw-delx-plugin.git"
  },
  "homepage": "https://github.com/davidmosiah/openclaw-delx-plugin",
  "bugs": {
    "url": "https://github.com/davidmosiah/openclaw-delx-plugin/issues"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "tools": [
      "delx_recover_incident",
      "delx_process_failure",
      "delx_report_recovery_outcome",
      "delx_daily_checkin",
      "delx_heartbeat_sync",
      "delx_close_session"
    ],
    "compat": {
      "pluginApi": "^1.2.0"
    },
    "build": {
      "openclawVersion": "2026.3.14",
      "pluginSdkVersion": "2026.3.14"
    }
  }
}
